# Cherished Motion Lab - Backend Environment Variables (Example)
# Copy this file to .env and fill in your actual values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=cherished-motion-videos

# External APIs
OPENAI_API_KEY=sk-your-openai-key-here
KLING_API_KEY=your-kling-api-key-here
KLING_API_URL=https://api.kling.ai/v1

# JWT
JWT_SECRET_KEY=generate-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Admin User
ADMIN_EMAIL=luke@cherishedmotion.com
ADMIN_PASSWORD=changeme123

# CORS
CUSTOMER_SITE_URL=http://localhost:3000
ADMIN_SITE_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Service
RESEND_API_KEY=your-resend-api-key-here

# App Settings
DEBUG=True
LOG_LEVEL=INFO
